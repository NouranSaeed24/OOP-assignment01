using System.Diagnostics.Metrics;
using System.Security.Cryptography.X509Certificates;
using System.Threading.Channels;
public class Tickets
{
    private string movieName;
    private string type;
    private string seat;
    private int price;
    private static int count = 0;

    public Tickets() { }

    public Tickets(string moviename, string type = "Standard", string seat = "A1")
    {
        MovieName = moviename;
        Type = type;
        Seat = seat;

        count++;

        if (type.ToLower() == "vip")
            price = 100;
        else if (type.ToLower() == "imax")
            price = 200;
        else
            price = 50;
    }

    public int TicketId
    {
        get 
        {
            count++;
            return 1000 + count; 
        }
    }

    public static int GetTotalTicketsSold()
    {
        return count;
    }

    public string MovieName
    {
        get { return movieName; }
        set
        {
            if (!string.IsNullOrEmpty(value))
                movieName = value;
        }
    }

    public string Type
    {
        get { return type; }
        set { type = value; }
    }

    public string Seat
    {
        get { return seat; }
        set { seat = value; }
    }

    public int Price
    {
        get { return price; }
    }

    public double PriceAfterTax
    {
        get { return price * 1.14; }
    }

    public double ApplyDiscount(double discountAmount)
    {
        if (discountAmount > 0 && discountAmount < price)
            return PriceAfterTax - discountAmount;

        return PriceAfterTax;
    }

    public void PrintTicket()
    {
        Console.Write($"Ticket ID: {TicketId} | ");
        Console.Write($"Movie: {MovieName} | ");
        Console.Write($"Type: {Type} | ");
        Console.Write($"Seat: {Seat} | ");
        Console.Write($"Price: {Price} | ");
        Console.WriteLine($"Price After Tax: { PriceAfterTax:F2}");
    }
}




class Cinema
{
    private Tickets[] ticket = new Tickets[20];

    // Indexer
    public Tickets this[int index]
    {
        get
        {
            if (index >= 0 && index < ticket.Length)
                return ticket[index];
            return null;
        }
        set
        {
            if (index >= 0 && index < ticket.Length)
                ticket[index] = value;
        }
    }

    // Get Movie By Name
    public Tickets GetMovieByName(string movieName)
    {
        for (int i = 0; i < ticket.Length; i++)
        {
            if (ticket[i] != null && ticket[i].MovieName == movieName)
            {
                return ticket[i];
            }
        }
        return null;
    }

    // Add Ticket
    public bool AddTicket(Tickets t)
    {
        for (int i = 0; i < ticket.Length; i++)
        {
            if (ticket[i] == null)
            {
                ticket[i] = t;
                return true;
            }
        }

        return false;
    }
}





static class BookingHelper
{
    private static int _counter;
    public static double CalcGroupDiscount(int numberOfTickets, double pricePerTicket)
    {
        double total = numberOfTickets * pricePerTicket;

        if (numberOfTickets >= 5)
        {
            double discount = total * 0.10;
            return total - discount;
        }

        return total;
    }
    public static string GenerateBookingReference()
    {
        _counter++;
        return $"BK-{_counter}";
    }
}




